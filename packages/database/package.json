    "predev": "pnpm run generate",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "@prisma/adapter-pg": "^7.9.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "prisma": "^7.2.0",
    "typescript": "^5.9.3",
    "tsx": "^4.19.2"
  }
}
